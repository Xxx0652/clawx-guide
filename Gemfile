source "https://rubygems.org"

gem "jekyll", "~> 4.3.0"
gem "minima", "~> 2.5"

# Jekyll plugins
gem "jekyll-feed", "~> 0.17.0"
gem "jekyll-seo-tag", "~> 2.8.0"
gem "jekyll-sitemap", "~> 1.4.0"
gem "jekyll-archives", "~> 2.2.0"

# For Windows
gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw]

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-archives"
end

# Performance
gem "kramdown", "~> 2.4.0"
gem "kramdown-parser-gfm", "~> 1.1.0"

# Windows JRuby support
platforms :mingw, :x64_mingw, :mswin do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

# Performance optimization
gem "jekyll-minifier", "~> 0.1.10"

# Allow safe caching on Windows
gem "webrick", "~> 1.8"
